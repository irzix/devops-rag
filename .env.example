# JWT Configuration (Change these to secure values in production)
JWT_SECRET_KEY=replace_this_with_a_long_random_secret_key_for_security
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Symmetric encryption key for target server credentials (SSH passwords and private keys)
# Generate a valid key using: cryptography.fernet.Fernet.generate_key().decode()
ENCRYPTION_KEY=replace_this_with_a_base64_fernet_key_for_security

# OpenRouter API configurations for AI Agent
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash

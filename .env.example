# ──────────────────────────────────────────────────────────────
# DevOps Copilot — Environment Configuration
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── LLM Provider (choose ONE) ────────────────────────────────

# Option 1: Ollama (FREE, local — recommended for development)
# Install Ollama: https://ollama.com/download
# Then: ollama pull qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# Option 2: OpenRouter (cloud — requires API key)
# Get your key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=google/gemini-2.5-flash

# ── JWT Authentication ────────────────────────────────────────
JWT_SECRET_KEY=replace_this_with_a_long_random_secret_key_for_security
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Encryption ────────────────────────────────────────────────
# Symmetric encryption key for target server credentials (SSH passwords and private keys)
# Generate a valid key using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace_this_with_a_base64_fernet_key_for_security

# ── LangSmith Observability (optional) ────────────────────────
# Traces LangGraph execution, tools, and memory nodes
# Get your API key at: https://smith.langchain.com
# For EU data residency use: https://eu.api.smith.langchain.com
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your_langsmith_api_key_here
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_PROJECT=devops-copilot
